APP_NAME=OK Action API
ENVIRONMENT=development

# Cloud SQL Connection (via Python Connector)
GCP_PROJECT_ID=
GCP_REGION=
GCP_INSTANCE_NAME=
DB_USER=
DB_PASSWORD=
DB_NAME=

# JWT
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# CORS
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Gemini AI
GEMINI_API_KEY=

# Backblaze B2 (S3-compatible storage)
S3_BUCKET=ok-actionbucket
S3_ENDPOINT_URL=https://s3.us-east-005.backblazeb2.com
AWS_REGION=us-east-005
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
